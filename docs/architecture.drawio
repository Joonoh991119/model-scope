<mxfile host="model-scope">
  <diagram name="model-scope-architecture">
    <mxGraphModel dx="900" dy="600" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="980" pageHeight="430" math="0" shadow="0" background="#f4f3ee">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="t1" value="&lt;b&gt;How it is built&lt;/b&gt;  —  adding a model is one declarative entry; everything else is generated" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=16;fontColor=#33312c;" vertex="1" parent="1"><mxGeometry x="24" y="18" width="940" height="24" as="geometry"/></mxCell>

        <mxCell id="b1" value="&lt;b&gt;The plugin&lt;/b&gt;&lt;br&gt;&lt;br&gt;skill, agent,&lt;br&gt;commands, modelbook" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#ffffff;strokeColor=#4a7a93;fontSize=13.5;fontColor=#33312c;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="24" y="54" width="218" height="96" as="geometry"/></mxCell>
        <mxCell id="b2" value="&lt;b&gt;Template&lt;/b&gt;&lt;br&gt;&lt;br&gt;index.html, engine.js,&lt;br&gt;plot.js, validate.mjs" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#ffffff;strokeColor=#4a7a93;fontSize=13.5;fontColor=#33312c;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="266" y="54" width="218" height="96" as="geometry"/></mxCell>
        <mxCell id="b3" value="&lt;b&gt;Add one MODELS entry&lt;/b&gt;&lt;br&gt;&lt;br&gt;params, simulate(), views&lt;br&gt;you edit only engine.js" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#eef3f5;strokeColor=#b07d2a;fontSize=13.5;fontColor=#33312c;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="508" y="54" width="218" height="96" as="geometry"/></mxCell>
        <mxCell id="b4" value="&lt;b&gt;Interactive explorer&lt;/b&gt;&lt;br&gt;&lt;br&gt;open index.html&lt;br&gt;or serve it" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#ffffff;strokeColor=#4a7a93;fontSize=13.5;fontColor=#33312c;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="750" y="54" width="206" height="96" as="geometry"/></mxCell>
        <mxCell id="e1" style="endArrow=block;html=1;rounded=1;strokeColor=#6f6b61;strokeWidth=2.5;" edge="1" parent="1" source="b1" target="b2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" style="endArrow=block;html=1;rounded=1;strokeColor=#6f6b61;strokeWidth=2.5;" edge="1" parent="1" source="b2" target="b3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" value="validate.mjs passes" style="endArrow=block;html=1;rounded=1;strokeColor=#6f6b61;strokeWidth=2.5;fontSize=11;fontColor=#6f6b61;" edge="1" parent="1" source="b3" target="b4"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="t2" value="&lt;b&gt;How it runs&lt;/b&gt;  —  every control re-runs the model and redraws the views" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=16;fontColor=#33312c;" vertex="1" parent="1"><mxGeometry x="24" y="196" width="940" height="24" as="geometry"/></mxCell>

        <mxCell id="r1" value="&lt;b&gt;Move a slider&lt;/b&gt;&lt;br&gt;or toggle" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fillColor=#ffffff;strokeColor=#4a7a93;fontSize=13.5;fontColor=#33312c;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="24" y="232" width="218" height="80" as="geometry"/></mxCell>
        <mxCell id="r2" value="&lt;b&gt;simulate(params)&lt;/b&gt;&lt;br&gt;returns the data" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fillColor=#ffffff;strokeColor=#4a7a93;fontSize=13.5;fontColor=#33312c;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="266" y="232" width="218" height="80" as="geometry"/></mxCell>
        <mxCell id="r3" value="&lt;b&gt;Each view draws&lt;/b&gt;&lt;br&gt;via the plotting helper" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fillColor=#ffffff;strokeColor=#4a7a93;fontSize=13.5;fontColor=#33312c;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="508" y="232" width="218" height="80" as="geometry"/></mxCell>
        <mxCell id="r4" value="&lt;b&gt;Canvas&lt;/b&gt;&lt;br&gt;you read the result" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fillColor=#ffffff;strokeColor=#4a7a93;fontSize=13.5;fontColor=#33312c;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="750" y="232" width="206" height="80" as="geometry"/></mxCell>
        <mxCell id="re1" style="endArrow=block;html=1;rounded=1;strokeColor=#6f6b61;strokeWidth=2.5;" edge="1" parent="1" source="r1" target="r2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="re2" style="endArrow=block;html=1;rounded=1;strokeColor=#6f6b61;strokeWidth=2.5;" edge="1" parent="1" source="r2" target="r3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="re3" style="endArrow=block;html=1;rounded=1;strokeColor=#6f6b61;strokeWidth=2.5;" edge="1" parent="1" source="r3" target="r4"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="note" value="The same engine.js is re-checked in Node by validate.mjs, so the math you read is the math that runs." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=13;fontColor=#6f6b61;" vertex="1" parent="1"><mxGeometry x="24" y="350" width="940" height="22" as="geometry"/></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
