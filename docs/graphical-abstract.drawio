<mxfile host="model-scope">
  <diagram name="model-scope-overview">
    <mxGraphModel dx="900" dy="600" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="960" pageHeight="470" math="0" shadow="0" background="#f4f3ee">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="model-scope" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=30;fontStyle=1;fontColor=#33312c;" vertex="1" parent="1"><mxGeometry x="40" y="22" width="880" height="36" as="geometry"/></mxCell>
        <mxCell id="sub" value="Replicate a model, illuminate it from the angles that fit its class, and compare what changes." style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=16;fontColor=#6f6b61;" vertex="1" parent="1"><mxGeometry x="40" y="60" width="880" height="24" as="geometry"/></mxCell>

        <mxCell id="b1" value="&lt;b&gt;1&amp;nbsp; Replicate&lt;/b&gt;&lt;br&gt;&lt;br&gt;From a paper, via a short interview: a faithful, interactive simulator." style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#4a7a93;fontSize=15;fontColor=#33312c;align=center;verticalAlign=middle;spacing=12;shadow=1;" vertex="1" parent="1"><mxGeometry x="30" y="104" width="288" height="170" as="geometry"/></mxCell>
        <mxCell id="b2" value="&lt;b&gt;2&amp;nbsp; Illuminate&lt;/b&gt;&lt;br&gt;&lt;br&gt;From the angles that fit the model's class. Structure first where there is structure." style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#eef3f5;strokeColor=#b07d2a;fontSize=15;fontColor=#33312c;align=center;verticalAlign=middle;spacing=12;shadow=1;" vertex="1" parent="1"><mxGeometry x="336" y="104" width="288" height="170" as="geometry"/></mxCell>
        <mxCell id="b3" value="&lt;b&gt;3&amp;nbsp; Compare&lt;/b&gt;&lt;br&gt;&lt;br&gt;Sweep a parameter or switch the model; read off the qualitative and quantitative difference." style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#4a7a93;fontSize=15;fontColor=#33312c;align=center;verticalAlign=middle;spacing=12;shadow=1;" vertex="1" parent="1"><mxGeometry x="642" y="104" width="288" height="170" as="geometry"/></mxCell>
        <mxCell id="e1" style="endArrow=block;html=1;rounded=1;strokeColor=#6f6b61;strokeWidth=2.5;" edge="1" parent="1" source="b1" target="b2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" style="endArrow=block;html=1;rounded=1;strokeColor=#6f6b61;strokeWidth=2.5;" edge="1" parent="1" source="b2" target="b3"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="cls" value="Angles fit the class: a process model shows its likelihood and posterior; a decision model, evidence to a bound and RT/accuracy; a network, its wiring then activity and energy landscape; a vision model, its architecture then layer-by-layer transforms — and reinforcement learning, causal inference, working memory, and epidemic models in turn." style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#faf9f5;strokeColor=#d6d2c5;fontSize=13.5;fontColor=#33312c;align=center;verticalAlign=middle;spacing=10;" vertex="1" parent="1"><mxGeometry x="30" y="300" width="900" height="88" as="geometry"/></mxCell>

        <mxCell id="foot" value="no build step, runs in the browser, validated by a Node gate" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=13;fontColor=#6f6b61;" vertex="1" parent="1"><mxGeometry x="40" y="402" width="880" height="20" as="geometry"/></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
