        <mxCell id="r1l" value="&lt;b&gt;Decision / trial model&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=right;verticalAlign=middle;fontSize=13;fontColor=#33312c;" vertex="1" parent="1"><mxGeometry x="70" y="404" width="250" height="46" as="geometry"/></mxCell>
        <mxCell id="r1p" value="Step  →  Trial  →  Simulation&lt;br&gt;&lt;font style='font-size:10px;color:#6f6b61'&gt;atomic update  →  one trial  →  the statistics&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=30;fillColor=#eef3f5;strokeColor=#4a7a93;fontColor=#33312c;fontSize=13;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="345" y="404" width="885" height="46" as="geometry"/></mxCell>
