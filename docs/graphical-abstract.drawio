<mxfile host="model-scope">
  <diagram name="model-scope-overview">
    <mxGraphModel dx="980" dy="700" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1340" pageHeight="700" math="0" shadow="0" background="#f4f3ee">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="model-scope — replicate a model, illuminate it from many angles, compare what changes" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=21;fontStyle=1;fontColor=#33312c;" vertex="1" parent="1"><mxGeometry x="30" y="18" width="1280" height="28" as="geometry"/></mxCell>
        <mxCell id="sub" value="a Claude Code plugin: give it a paper, it interviews you, replicates the model as an interactive simulator, and lets you compare across parameters and model choices" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=12.5;fontColor=#6f6b61;" vertex="1" parent="1"><mxGeometry x="30" y="48" width="1280" height="20" as="geometry"/></mxCell>

        <mxCell id="a1" value="&lt;b&gt;Paper or equations&lt;/b&gt;&lt;br&gt;you provide only this" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fillColor=#ffffff;strokeColor=#4a7a93;fontSize=12.5;fontColor=#33312c;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="30" y="86" width="290" height="74" as="geometry"/></mxCell>
        <mxCell id="a2" value="&lt;b&gt;Interview&lt;/b&gt;&lt;br&gt;purpose, scope, which angles" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fillColor=#ffffff;strokeColor=#4a7a93;fontSize=12.5;fontColor=#33312c;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="360" y="86" width="290" height="74" as="geometry"/></mxCell>
        <mxCell id="a3" value="&lt;b&gt;Replicate &amp; build&lt;/b&gt;&lt;br&gt;validate + visual QC" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fillColor=#eef3f5;strokeColor=#b07d2a;fontSize=12.5;fontColor=#33312c;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="690" y="86" width="290" height="74" as="geometry"/></mxCell>
        <mxCell id="a4" value="&lt;b&gt;Interactive simulator&lt;/b&gt;&lt;br&gt;live sliders and toggles" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fillColor=#ffffff;strokeColor=#4a7a93;fontSize=12.5;fontColor=#33312c;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="1020" y="86" width="290" height="74" as="geometry"/></mxCell>
        <mxCell id="af1" style="endArrow=block;html=1;rounded=1;strokeColor=#6f6b61;strokeWidth=2;" edge="1" parent="1" source="a1" target="a2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="af2" style="endArrow=block;html=1;rounded=1;strokeColor=#6f6b61;strokeWidth=2;" edge="1" parent="1" source="a2" target="a3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="af3" style="endArrow=block;html=1;rounded=1;strokeColor=#6f6b61;strokeWidth=2;" edge="1" parent="1" source="a3" target="a4"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="bbox" value="" style="rounded=1;whiteSpace=wrap;html=1;arcSize=3;fillColor=#faf9f5;strokeColor=#d6d2c5;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="30" y="184" width="1280" height="300" as="geometry"/></mxCell>
        <mxCell id="btit" value="&lt;b&gt;Illuminate the model from the angles that fit its class&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=14;fontColor=#33312c;" vertex="1" parent="1"><mxGeometry x="50" y="196" width="1240" height="22" as="geometry"/></mxCell>

        <mxCell id="cl1" value="&lt;b&gt;Process model&lt;/b&gt;&lt;br&gt;(Bayesian observer)&lt;br&gt;&lt;br&gt;measurement, likelihood,&lt;br&gt;posterior&lt;br&gt;trial: stimulus to estimate&lt;br&gt;many trials: Var(θ), bias(θ)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#4a7a93;fontSize=11.5;fontColor=#33312c;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="52" y="228" width="296" height="240" as="geometry"/></mxCell>
        <mxCell id="cl2" value="&lt;b&gt;Decision&lt;/b&gt;&lt;br&gt;(drift-diffusion)&lt;br&gt;&lt;br&gt;one trial: evidence to a bound&lt;br&gt;many trials: RT &amp; accuracy&lt;br&gt;histograms&lt;br&gt;by coherence: correct vs error RT" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#4a7a93;fontSize=11.5;fontColor=#33312c;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="366" y="228" width="296" height="240" as="geometry"/></mxCell>
        <mxCell id="cl3" value="&lt;b&gt;Network&lt;/b&gt;&lt;br&gt;(recurrent circuit)&lt;br&gt;&lt;br&gt;structure: connectivity, E/I,&lt;br&gt;plasticity&lt;br&gt;activity: single-cell &amp; population&lt;br&gt;representation, attractor,&lt;br&gt;energy landscape" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#4a7a93;fontSize=11.5;fontColor=#33312c;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="680" y="228" width="296" height="240" as="geometry"/></mxCell>
        <mxCell id="cl4" value="&lt;b&gt;Vision / CNN&lt;/b&gt;&lt;br&gt;(layered sensory)&lt;br&gt;&lt;br&gt;structure: the architecture&lt;br&gt;layer-by-layer transform of&lt;br&gt;the input image&lt;br&gt;receptive fields, connectivity&lt;br&gt;tuning" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#4a7a93;fontSize=11.5;fontColor=#33312c;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="994" y="228" width="296" height="240" as="geometry"/></mxCell>
        <mxCell id="cmore" value="…and RL, MDP/POMDP, causal graphs, oscillations, transformers — the harness reasons about each model's purpose and its natural angles" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=11;fontColor=#6f6b61;" vertex="1" parent="1"><mxGeometry x="50" y="470" width="1240" height="14" as="geometry"/></mxCell>

        <mxCell id="cbar" value="&lt;b&gt;Compare&lt;/b&gt;  —  sweep a parameter or switch the model, and read off the qualitative and quantitative differences (overlaid curves, heatmaps, metrics)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=18;fillColor=#eef3f5;strokeColor=#4a7a93;fontSize=13;fontColor=#33312c;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="30" y="504" width="1280" height="58" as="geometry"/></mxCell>
        <mxCell id="bf1" style="endArrow=block;html=1;rounded=1;strokeColor=#6f6b61;strokeWidth=1.5;" edge="1" parent="1" source="bbox" target="cbar"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="foot" value="faithful replication, runs in the browser, validated by a Node gate, no build step" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=11.5;fontColor=#6f6b61;" vertex="1" parent="1"><mxGeometry x="30" y="574" width="1280" height="18" as="geometry"/></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
