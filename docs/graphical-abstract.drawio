        <mxCell id="s2" value="&lt;b&gt;TRANSFORM&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:10px'&gt;one update · filter channels · inference&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=18;fillColor=#4a7a93;strokeColor=none;fontColor=#ffffff;fontSize=13;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="370" y="314" width="250" height="56" as="geometry"/></mxCell>
