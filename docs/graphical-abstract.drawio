<mxfile host="model-scope">
  <diagram name="model-scope-graphical-abstract">
    <mxGraphModel dx="900" dy="640" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1300" pageHeight="620" math="0" shadow="0" background="#f4f3ee">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="model-scope — turn any model into an interactive explorer you can think with" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=22;fontStyle=1;fontColor=#33312c;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="1220" height="30" as="geometry"/></mxCell>
        <mxCell id="sub" value="a Claude Code plugin — give it a paper, it interviews you, then builds &amp; serves an interactive GUI" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=13;fontColor=#6f6b61;" vertex="1" parent="1"><mxGeometry x="40" y="52" width="1220" height="22" as="geometry"/></mxCell>

        <mxCell id="c1" value="&lt;b&gt;1 · Reference&lt;/b&gt;&lt;br&gt;&lt;br&gt;any paper or equations&lt;br&gt;&lt;i&gt;you supply only this&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#ffffff;strokeColor=#4a7a93;fontSize=13;fontColor=#33312c;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="40" y="100" width="250" height="120" as="geometry"/></mxCell>
        <mxCell id="c2" value="&lt;b&gt;2 · Auto-interview&lt;/b&gt;&lt;br&gt;&lt;br&gt;purpose · scope ·&lt;br&gt;perspectives · conditions" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#ffffff;strokeColor=#4a7a93;fontSize=13;fontColor=#33312c;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="360" y="100" width="250" height="120" as="geometry"/></mxCell>
        <mxCell id="c3" value="&lt;b&gt;3 · The harness builds it&lt;/b&gt;&lt;br&gt;&lt;br&gt;one entry: params → simulate() → views&lt;br&gt;+ validate gate + visual QC" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#eef3f5;strokeColor=#b07d2a;fontSize=13;fontColor=#33312c;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="680" y="100" width="250" height="120" as="geometry"/></mxCell>
        <mxCell id="c4" value="&lt;b&gt;4 · Interactive GUI&lt;/b&gt;&lt;br&gt;&lt;br&gt;live sliders · lens switch&lt;br&gt;served at a local URL" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#ffffff;strokeColor=#4a7a93;fontSize=13;fontColor=#33312c;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1"><mxGeometry x="1000" y="100" width="250" height="120" as="geometry"/></mxCell>

        <mxCell id="e1" style="endArrow=block;html=1;rounded=1;strokeColor=#6f6b61;strokeWidth=2;" edge="1" parent="1" source="c1" target="c2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" style="endArrow=block;html=1;rounded=1;strokeColor=#6f6b61;strokeWidth=2;" edge="1" parent="1" source="c2" target="c3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" style="endArrow=block;html=1;rounded=1;strokeColor=#6f6b61;strokeWidth=2;" edge="1" parent="1" source="c3" target="c4"><mxGeometry relative="1" as="geometry"/></mxCell>

